---
import "../styles/global.css";
import ContactPopup from "../components/ContactPopup.astro";
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>KAZDRONE SOLUTIONS</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Geist:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
        <style>
            :root {
                --primary: #d8e6fd;
                --accent: #c4dafc;
                --background: #ffffff;
                --text-primary: #171717;
            }
            body {
                font-family: "Geist", "Inter", sans-serif;
            }
            h1,
            h2,
            h3,
            h4,
            h5,
            h6 {
                font-family: "Plus Jakarta Sans", sans-serif;
            }
            @keyframes beam-spin {
                from {
                    transform: rotate(0deg);
                }
                to {
                    transform: rotate(360deg);
                }
            }
            @keyframes dots-move {
                from {
                    background-position: 0 0;
                }
                to {
                    background-position: 24px 24px;
                }
            }
            .shadow-5xl {
                box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.5);
            }
        </style>
    </head>
    <body class="antialiased text-[#171717] bg-white">
        <slot />
        <ContactPopup />
        <script>
            import { translations } from "../i18n/translations";
            type Lang = "en" | "ru" | "kz";

            function applyTranslations(lang: Lang) {
                const t = translations[lang];
                document.querySelectorAll("[data-i18n]").forEach((el) => {
                    const key = el.getAttribute("data-i18n") as keyof typeof t;
                    if (key in t) el.textContent = t[key];
                });
                document.querySelectorAll("[data-i18n-html]").forEach((el) => {
                    const key = el.getAttribute("data-i18n-html") as keyof typeof t;
                    if (key in t) el.innerHTML = t[key];
                });
                document.querySelectorAll("[data-i18n-placeholder]").forEach((el) => {
                    const key = el.getAttribute("data-i18n-placeholder") as keyof typeof t;
                    if (key in t) (el as HTMLInputElement).placeholder = t[key];
                });
                // Update lang button active states
                document.querySelectorAll("[data-lang]").forEach((btn) => {
                    const btnLang = btn.getAttribute("data-lang");
                    if (btnLang === lang) {
                        btn.classList.add("bg-white", "text-slate-900", "shadow-sm");
                        btn.classList.remove("text-slate-500");
                    } else {
                        btn.classList.remove("bg-white", "text-slate-900", "shadow-sm");
                        btn.classList.add("text-slate-500");
                    }
                });
            }

            function setLang(lang: Lang) {
                localStorage.setItem("lang", lang);
                applyTranslations(lang);
            }

            const saved = (localStorage.getItem("lang") as Lang) || "en";
            applyTranslations(saved);

            document.addEventListener("click", (e) => {
                const target = (e.target as HTMLElement).closest("[data-lang]");
                if (target) {
                    setLang(target.getAttribute("data-lang") as Lang);
                }
            });

            (window as any).setLang = setLang;
        </script>
    </body>
</html>

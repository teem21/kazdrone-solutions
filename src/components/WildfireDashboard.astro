<section class="py-12 px-4 md:px-8 bg-slate-50 overflow-hidden" id="dashboard">
    <div class="max-w-screen-2xl mx-auto text-center mb-8 px-4">
        <h2
            class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 uppercase tracking-tight"
         data-i18n="wf_dash_title">
            Wildfire Command Dashboard
        </h2>
        <p class="text-slate-500 max-w-2xl mx-auto text-lg leading-relaxed" data-i18n="wf_dash_desc">
            Centralize real-time fire intelligence. Monitor ignition alerts,
            track wind vectors, and coordinate aerial and ground assets from a
            unified command interface.
        </p>
    </div>

    <div class="max-w-screen-2xl mx-auto relative group">
        <!-- Dashboard UI Container -->
        <div
            class="relative rounded-[32px] overflow-hidden shadow-5xl bg-[#05070A] border border-white/10 h-[800px] flex"
        >
            <!-- Sidebar -->
            <aside
                class="w-64 hidden lg:flex flex-col bg-[#05070A] border-r border-white/5 text-white z-30"
            >
                <div class="p-8 flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-xl bg-blue-600 flex items-center justify-center shadow-lg shadow-blue-500/30"
                    >
                        <span
                            class="material-symbols-outlined text-white font-light"
                            >local_fire_department</span
                        >
                    </div>
                    <div>
                        <h1
                            class="font-bold text-lg tracking-tight leading-none"
                        >
                            KAZDRONE
                        </h1>
                        <p
                            class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1"
                         data-i18n="wf_dash_ops">
                            Fire Ops
                        </p>
                    </div>
                </div>
                <nav class="flex-1 px-4 py-4 space-y-1">
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl bg-blue-600 text-white font-medium transition-all shadow-lg shadow-blue-500/20"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >grid_view</span
                        >
                        <span class="text-sm" data-i18n="wf_dash_nav_cmd">Command Center</span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >map</span
                        >
                        <span class="text-sm" data-i18n="wf_dash_nav_sectors">Active Sectors</span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >flight</span
                        >
                        <span class="text-sm" data-i18n="wf_dash_nav_fleet">Drone Fleet</span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all relative cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >notifications</span
                        >
                        <span class="text-sm" data-i18n="wf_dash_nav_alerts">Ignition Alerts</span>
                        <span
                            class="absolute right-4 top-1/2 -translate-y-1/2 w-2 h-2 bg-[#3B82F6] rounded-full shadow-[0_0_12px_rgba(59,130,246,0.5)]"
                        ></span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >history</span
                        >
                        <span class="text-sm" data-i18n="wf_dash_nav_logs">Flight Logs</span>
                    </div>
                </nav>
            </aside>

            <!-- Main Content -->
            <main
                class="flex-1 flex flex-col relative overflow-hidden bg-white"
            >
                <header
                    class="h-16 border-b border-slate-200 bg-white/90 backdrop-blur-xl px-8 flex items-center justify-between z-20"
                >
                    <div class="flex items-center gap-8">
                        <h2
                            class="text-lg font-bold text-slate-800 tracking-tight"
                         data-i18n="wf_dash_header_title">
                            Active Surveillance Area
                        </h2>
                        <div
                            class="flex items-center gap-2 px-3 py-1.5 bg-blue-50/50 text-blue-600 rounded-full border border-blue-100"
                        >
                            <span
                                class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-pulse"
                            ></span>
                            <span
                                class="text-[10px] font-black uppercase tracking-widest"
                                 data-i18n="wf_dash_sys_status">Mission Status: Surveillance Active</span
                            >
                        </div>
                    </div>
                </header>

                <!-- Map Area -->
                <div class="flex-1 relative bg-slate-200 overflow-hidden">
                    <!-- Placeholder Satellite Map -->
                    <div
                        class="absolute inset-0 grayscale contrast-125 opacity-40 bg-green-900"
                        style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDRPqhgOykyu6IDT0v4II37qQpiLxiRgE6ARl2dcnL0mjS-t8fSVrQUjy4F-XExDFyO-L6UQMexyLpUb1Fi19KEyMcnQkPzHp7z0dNZQKinON2CIqPvi3B-bw894tACkesHxRJ7GIBprrnpQNOCgy708G5cmDRlK6WLZNPDUyO6w2oa8ivOLSOBVxVcyYsMdASaWRsq9p4-HbmvsqRg87eEBx6GgWfenr9nHALbhPODjXY2WmrPYM-iz1xKzsvKwQr8t8OVm-dA5OQ'); background-size: cover; filter: sepia(100%) saturate(150%) hue-rotate(60deg);"
                    >
                    </div>

                    <!-- Heat Map Overlay -->
                    <div
                        class="absolute inset-0 bg-red-600/10 pointer-events-none mix-blend-overlay"
                    >
                    </div>

                    <!-- Markers -->
                    <div
                        class="absolute top-[35%] left-[55%] group/marker cursor-pointer"
                    >
                        <div class="relative flex items-center justify-center">
                            <div
                                class="absolute w-16 h-16 bg-blue-600 rounded-full opacity-20 animate-ping"
                            >
                            </div>
                            <div
                                class="relative w-6 h-6 bg-white rounded-full border-4 border-blue-600 shadow-2xl flex items-center justify-center"
                            >
                                <span
                                    class="material-symbols-outlined text-blue-600 scale-50"
                                    >flame</span
                                >
                            </div>
                            <div
                                class="absolute bottom-12 left-1/2 -translate-x-1/2 bg-white px-5 py-3 rounded-2xl shadow-2xl border border-slate-100 min-w-[240px] z-40 transition-all group-hover/marker:scale-105"
                            >
                                <p
                                    class="text-[10px] uppercase font-black text-blue-600 mb-1 flex items-center gap-1"
                                >
                                    <span
                                        class="material-symbols-outlined text-sm"
                                        >priority_high</span
                                     data-i18n="wf_dash_ign_det">
                                    Ignition Detected
                                </p>
                                <p class="text-sm font-bold text-slate-800" data-i18n="wf_dash_high_heat">
                                    High-Heat Signature: Sector 9-G
                                </p>
                                <div
                                    class="mt-2 pt-2 border-t border-slate-50 flex justify-between uppercase tracking-tighter"
                                >
                                    <p
                                        class="text-[10px] text-slate-400 font-bold"
                                     data-i18n="wf_dash_latlon">
                                        Lat: 48.12 • Lon: 11.24
                                    </p>
                                    <p
                                        class="text-[10px] text-blue-600 font-black"
                                     data-i18n="wf_dash_verified">
                                        VERIFIED AI
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- HUD Controls -->
                    <div class="absolute bottom-8 right-8 flex flex-col gap-2">
                        <button
                            class="w-12 h-12 bg-white rounded-xl shadow-xl border border-slate-100 flex items-center justify-center text-slate-600 hover:text-blue-600 transition-all"
                        >
                            <span class="material-symbols-outlined">add</span>
                        </button>
                        <button
                            class="w-12 h-12 bg-white rounded-xl shadow-xl border border-slate-100 flex items-center justify-center text-slate-600 hover:text-blue-600 transition-all"
                        >
                            <span class="material-symbols-outlined">remove</span
                            >
                        </button>
                    </div>

                    <div class="absolute top-8 left-8">
                        <div
                            class="bg-white/90 backdrop-blur-xl p-6 rounded-2xl shadow-2xl border border-white min-w-[260px]"
                        >
                            <p
                                class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3"
                             data-i18n="wf_dash_cov_goal">
                                Daily Coverage Goal
                            </p>
                            <div class="flex items-end gap-2 mb-4">
                                <span
                                    class="text-5xl font-black text-slate-800 leading-none"
                                    >8,420</span
                                >
                                <span
                                    class="text-sm text-slate-400 font-bold mb-1 uppercase tracking-tighter"
                                     data-i18n="wf_dash_hectares">HECTARES</span
                                >
                            </div>
                            <div
                                class="w-full bg-slate-100 h-3 rounded-full overflow-hidden p-0.5"
                            >
                                <div
                                    class="bg-blue-600 h-full w-[78%] rounded-full shadow-[0_0_12px_rgba(37,99,235,0.4)] transition-all duration-1000"
                                >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Right Sidebar: Detection Feed -->
            <aside
                class="w-80 hidden xl:flex flex-col border-l border-slate-200 bg-white z-20"
            >
                <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                    <h3
                        class="font-extrabold text-slate-800 text-lg flex items-center gap-2"
                    >
                        <span class="material-symbols-outlined text-blue-600"
                            >thermostat</span
                        >
                        <span data-i18n="wf_dash_therm_intel">Thermal Intelligence</span>
                    </h3>
                    <p
                        class="text-[11px] text-slate-500 font-medium mt-1 uppercase tracking-tighter"
                     data-i18n="wf_dash_live_front">
                        Live Front Tracking
                    </p>
                </div>

                <div class="flex-1 overflow-y-auto p-4 space-y-4">
                    <!-- Feed Item 1 -->
                    <div
                        class="bg-white rounded-2xl p-4 border border-blue-200 shadow-sm group hover:shadow-xl hover:border-blue-600 transition-all duration-300"
                    >
                        <div
                            class="relative rounded-xl overflow-hidden aspect-video mb-4"
                        >
                            <img
                                src="/assets/wildfire_thermal.png"
                                alt="Hotspot"
                                class="w-full h-full object-cover"
                            />
                            <div
                                class="absolute inset-0 bg-red-600/30 mix-blend-overlay"
                            >
                            </div>
                            <div
                                class="absolute top-2 left-2 px-2 py-1 bg-blue-600 text-white text-[9px] font-black rounded uppercase tracking-widest shadow-lg"
                             data-i18n="wf_dash_crit_heat">
                                CRITICAL HEAT: 340°C
                            </div>
                        </div>
                        <div class="flex justify-between items-start">
                            <div>
                                <h4 class="text-sm font-bold text-slate-800" data-i18n="wf_dash_prim_ign">
                                    Primary Ignition
                                </h4>
                                <p
                                    class="text-[10px] text-slate-400 font-bold uppercase mt-0.5"
                                 data-i18n="wf_dash_zone_alpha">
                                    Zone Alpha • 11:21 AM
                                </p>
                            </div>
                            <div
                                class="bg-blue-50 px-2 py-1 rounded-lg border border-blue-100 text-[10px] font-black text-blue-600"
                            >
                                99.8% CI
                            </div>
                        </div>
                    </div>

                    <!-- Feed Item 2 -->
                    <div
                        class="bg-white rounded-2xl p-4 border border-slate-100 shadow-sm group hover:shadow-xl hover:border-blue-600 transition-all duration-300 opacity-60"
                    >
                        <div
                            class="relative rounded-xl overflow-hidden aspect-video mb-4"
                        >
                            <img
                                src="/assets/s.jpg"
                                alt="Visual Confirm"
                                class="w-full h-full object-cover"
                            />
                            <div
                                class="absolute top-2 left-2 px-2 py-1 bg-slate-800 text-white text-[9px] font-black rounded uppercase tracking-widest shadow-lg"
                             data-i18n="wf_dash_smoke_col">
                                SMOKE COLUMN
                            </div>
                        </div>
                        <div class="flex justify-between items-start">
                            <div>
                                <h4
                                    class="text-sm font-bold text-slate-800 tracking-tight"
                                 data-i18n="wf_dash_vis_val">
                                    Visual Validation
                                </h4>
                                <p
                                    class="text-[10px] text-slate-400 font-bold uppercase mt-0.5"
                                 data-i18n="wf_dash_west_ridge">
                                    West Ridge • 11:04 AM
                                </p>
                            </div>
                            <div
                                class="bg-slate-50 px-2 py-1 rounded-lg border border-slate-100 text-[10px] font-black text-slate-500"
                            >
                                92.1% CI
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Telemetry -->
                <div class="p-6 bg-slate-50 border-t border-slate-100 mt-auto">
                    <div class="flex items-center justify-between mb-4">
                        <span
                            class="text-[10px] font-black text-slate-400 uppercase tracking-widest"
                             data-i18n="wf_dash_force_status">Force Status</span
                        >
                        <div class="flex items-center gap-1.5">
                            <span
                                class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-pulse shadow-[0_0_8px_rgba(37,99,235,0.6)]"
                            ></span>
                            <span
                                class="text-[9px] font-bold text-blue-600 uppercase tracking-tighter"
                                 data-i18n="wf_dash_cmd_sync">Command Sync</span
                            >
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div
                            class="bg-white p-3 rounded-xl border border-slate-200 shadow-sm"
                        >
                            <p
                                class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1"
                             data-i18n="wf_dash_cur_wind">
                                Current Wind
                            </p>
                            <p
                                class="text-xl font-black text-slate-800 leading-none"
                            >
                                24<span
                                    class="text-xs text-slate-400 font-medium ml-0.5"
                                    >km/h</span
                                >
                            </p>
                        </div>
                        <div
                            class="bg-white p-3 rounded-xl border border-slate-200 shadow-sm"
                        >
                            <p
                                class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1"
                             data-i18n="wf_dash_drone_range">
                                Drone Range
                            </p>
                            <p
                                class="text-xl font-black text-slate-800 leading-none"
                            >
                                320<span
                                    class="text-xs text-slate-400 font-medium ml-0.5"
                                    >km</span
                                >
                            </p>
                        </div>
                    </div>
                </div>
            </aside>
        </div>

        <!-- External Glow -->
        <div
            class="absolute -inset-10 bg-blue-500/10 blur-[100px] -z-10 group-hover:bg-blue-500/20 transition-colors duration-1000"
        >
        </div>
    </div>
</section>

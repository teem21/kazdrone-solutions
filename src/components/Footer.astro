---
import { Twitter, Instagram, Linkedin, Mail } from "lucide-astro";
---

<footer
    class="bg-slate-950 text-slate-400 py-20 px-4 md:px-8 border-t border-slate-900"
>
    <div class="max-w-screen-2xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-16 mb-20">
            <div class="col-span-1 md:col-span-1">
                <a href="/" class="flex items-center gap-2 mb-8">
                    <span class="text-2xl font-bold tracking-tighter text-white"
                        >KAZDRONE<span class="text-blue-500"> SOLUTIONS</span>
                    </span>
                </a>
                <p class="text-sm leading-relaxed mb-8 max-w-xs">
                    Leading provider of enterprise drone solutions and
                    AI-powered aerial intelligence. Transforming industries
                    through precision and automation.
                </p>
                <div class="flex gap-4">
                    <a
                        href="#"
                        class="p-2 bg-slate-900 rounded-full hover:bg-blue-600 hover:text-white transition-all"
                        ><Twitter size={20} />
                    </a>
                    <a
                        href="#"
                        class="p-2 bg-slate-900 rounded-full hover:bg-blue-600 hover:text-white transition-all"
                        ><Instagram size={20} />
                    </a>
                    <a
                        href="#"
                        class="p-2 bg-slate-900 rounded-full hover:bg-blue-600 hover:text-white transition-all"
                        ><Linkedin size={20} />
                    </a>
                </div>
            </div>

            <div>
                <h4
                    class="text-white font-bold mb-8 uppercase tracking-widest text-sm"
                >
                    Industries
                </h4>
                <ul class="space-y-4 text-sm">
                    <li>
                        <a
                            href="#"
                            class="hover:text-blue-400 transition-colors"
                            >Public Safety</a
                        >
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-blue-400 transition-colors"
                            >Nature protection
                        </a>
                    </li>
                    <li>
                        <a
                            href="/pipeline-solution"
                            class="hover:text-blue-400 transition-colors"
                            >Oil & Gas</a
                        >
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-blue-400 transition-colors"
                            >Electricity</a
                        >
                    </li>
                </ul>
            </div>

            <div>
                <h4
                    class="text-white font-bold mb-8 uppercase tracking-widest text-sm"
                >
                    Solutions
                </h4>
                <ul class="space-y-4 text-sm">
                    <li>
                        <a
                            href="#"
                            class="hover:text-blue-400 transition-colors"
                            >ERP Integration</a
                        >
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-blue-400 transition-colors"
                            >Custom AI training</a
                        >
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-blue-400 transition-colors"
                            >Data collection</a
                        >
                    </li>
                    <li>
                        <a
                            href="#"
                            class="hover:text-blue-400 transition-colors"
                            >IoT Systems</a
                        >
                    </li>
                </ul>
            </div>

            <div
                class="pt-8 border-t border-slate-900 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] uppercase tracking-widest font-bold"
            >
                <p>© 2026 KAZDRONE SOLUTIONS. All rights reserved.</p>
                <div class="flex gap-8">
                    <a href="#" class="hover:text-white transition-colors"
                        >Privacy Policy</a
                    >
                    <a href="#" class="hover:text-white transition-colors"
                        >Terms of Service</a
                    >
                    <a href="#" class="hover:text-white transition-colors"
                        >Cookie Settings</a
                    >
                </div>
            </div>
        </div>
    </div>
</footer>

---
import { Shield, Target, Radio } from "lucide-astro";
---

<section class="py-12 px-4 md:px-8 bg-white">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Benefit 1 -->
        <div
            class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1"
        >
            <div
                class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"
            >
                <Shield size={28} />
            </div>
            <h3
                class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
            >
                Zero-Gap Surveillance
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed">
                Eliminate physical patrol blind spots with autonomous drone
                corridors that provide persistent, overlapping coverage of
                border zones.
            </p>
        </div>

        <!-- Benefit 2 -->
        <div
            class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1"
        >
            <div
                class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"
            >
                <Target size={28} />
            </div>
            <h3
                class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
            >
                AI Target Recognition
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed">
                Automatically detect and classify people, vehicles, and maritime
                vessels with specialized edge-AI algorithms in real-time.
            </p>
        </div>

        <!-- Benefit 3 -->
        <div
            class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1"
        >
            <div
                class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"
            >
                <Radio size={28} />
            </div>
            <h3
                class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
            >
                Encrypted Data Mesh
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed">
                Maintain secure, low-latency transmission of 4K video and
                mission data across vast distances using military-grade
                encryption.
            </p>
        </div>
    </div>
</section>

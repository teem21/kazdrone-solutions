---
import { Send } from "lucide-astro";
---

<section class="py-24 px-4 md:px-8 bg-slate-50">
    <div class="max-w-screen-xl mx-auto text-center">
        <h2
            class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 uppercase"
        >
            Request a Demo
        </h2>
        <p class="text-slate-500 mb-16 max-w-2xl mx-auto">
            Describe result you want to achieve with our technology leverage and
            we will show you how to do it.
        </p>

        <form
            class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl border border-slate-100 flex flex-col gap-6 text-left"
        >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label
                        class="text-xs font-bold text-slate-400 uppercase tracking-widest ml-1"
                        >Name</label
                    >
                    <input
                        type="text"
                        placeholder="Your Name"
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-blue-500 focus:outline-none transition-all"
                    />
                </div>
                <div class="space-y-2">
                    <label
                        class="text-xs font-bold text-slate-400 uppercase tracking-widest ml-1"
                        >Email</label
                    >
                    <input
                        type="email"
                        placeholder="email@example.com"
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-blue-500 focus:outline-none transition-all"
                    />
                </div>
                <div class="space-y-2">
                    <label
                        class="text-xs font-bold text-slate-400 uppercase tracking-widest ml-1"
                        >Tel</label
                    >
                    <input
                        type="tel"
                        placeholder="+1 (555) 000-0000"
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-blue-500 focus:outline-none transition-all"
                    />
                </div>
                <div class="space-y-2">
                    <label
                        class="text-xs font-bold text-slate-400 uppercase tracking-widest ml-1"
                        >WhatsApp / Organization</label
                    >
                    <input
                        type="text"
                        placeholder="Company Name"
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-blue-500 focus:outline-none transition-all"
                    />
                </div>
            </div>

            <div class="space-y-2">
                <label
                    class="text-xs font-bold text-slate-400 uppercase tracking-widest ml-1"
                    >Message</label
                >
                <textarea
                    rows="4"
                    placeholder="How can we help you?"
                    class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-blue-500 focus:outline-none transition-all resize-none"
                ></textarea>
            </div>

            <button
                type="submit"
                class="w-full md:w-auto bg-slate-900 text-white px-10 py-5 rounded-2xl font-bold flex items-center justify-center gap-3 transition-all hover:bg-slate-800 active:scale-[0.98] mt-4 uppercase tracking-widest"
            >
                SUBMIT REQUEST <Send size={20} />
            </button>
        </form>
    </div>
</section>

---
import { Zap, Shield, Activity } from "lucide-astro";
---

<section class="py-12 px-4 md:px-8 bg-white">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Benefit 1 -->
        <div
            class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1"
        >
            <div
                class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"
            >
                <Zap size={28} />
            </div>
            <h3
                class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
            >
                Automated Thermal Monitoring
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed">
                Continuous radiometric monitoring to detect hotspots in
                transformers and insulators before failure occurs.
            </p>
        </div>

        <!-- Benefit 2 -->
        <div
            class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1"
        >
            <div
                class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"
            >
                <Shield size={28} />
            </div>
            <h3
                class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
            >
                High-Voltage Safety
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed">
                Eliminate the need for technicians to work in close proximity to
                energized equipment during inspections.
            </p>
        </div>

        <!-- Benefit 3 -->
        <div
            class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1"
        >
            <div
                class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"
            >
                <Activity size={28} />
            </div>
            <h3
                class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
            >
                Predictive Maintenance
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed">
                Shift from reactive repairs to data-driven proactive
                maintenance, extending asset lifecycle significantly.
            </p>
        </div>
    </div>
</section>

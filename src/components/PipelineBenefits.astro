---
import { Zap, Radio, TrendingDown } from "lucide-astro";
---

<section class="py-12 px-4 md:px-8 bg-white">
    <div class="max-w-screen-xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"><Zap size={28} /></div>
            <h3 class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight" data-i18n="pipe_ben1_title">Real-time Defect Detection</h3>
            <p class="text-slate-500 text-sm leading-relaxed" data-i18n="pipe_ben1_desc">Instant identification of anomalies using on-board edge computing and proprietary AI models.</p>
        </div>
        <div class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"><Radio size={28} /></div>
            <h3 class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight" data-i18n="pipe_ben2_title">Remote Autonomous Operations</h3>
            <p class="text-slate-500 text-sm leading-relaxed" data-i18n="pipe_ben2_desc">Operate in high-risk or inaccessible terrain without deploying ground crews to site. Plan mission and create a system.</p>
        </div>
        <div class="p-10 rounded-3xl bg-slate-50 border border-slate-100 transition-all hover:shadow-xl hover:-translate-y-1">
            <div class="w-14 h-14 bg-blue-600/10 text-blue-600 rounded-2xl flex items-center justify-center mb-8"><TrendingDown size={28} /></div>
            <h3 class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight" data-i18n="pipe_ben3_title">Cost Efficiency</h3>
            <p class="text-slate-500 text-sm leading-relaxed" data-i18n="pipe_ben3_desc">Reduce inspection costs by up to 70% compared to traditional helicopter or foot-based surveys.</p>
        </div>
    </div>
</section>

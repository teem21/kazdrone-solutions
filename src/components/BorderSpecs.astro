---
import { Shield, Radio, Gauge, Cpu } from "lucide-astro";

const specs = [
    {
        icon: Shield,
        title: "Perimeter Stealth",
        description:
            "Low-acoustic signature and specialized coatings for discreet tactical observation.",
    },
    {
        icon: Radio,
        title: "Radar-AI Fusion",
        description:
            "Seamless integration with ground-based radar systems for cross-cueing identification.",
    },
    {
        icon: Gauge,
        title: "Endurance Ops",
        description:
            "Up to 8 hours of continuous regional surveillance with rapid hybrid recharging.",
    },
    {
        icon: Cpu,
        title: "Edge Processing",
        description:
            "On-board autonomous navigation and threat classification without satellite dependency.",
    },
];
---

<section class="py-24 bg-slate-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <div
                    class="absolute -top-20 -left-20 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl"
                >
                </div>

                <div
                    class="inline-block px-4 py-1.5 bg-blue-600/10 rounded-full mb-6"
                >
                    <span class="text-blue-600 text-[10px] font-bold uppercase tracking-[0.2em]" data-i18n="brd_spec_label">Mission Capabilities</span>
                </div>

                <h2 class="text-4xl md:text-5xl font-bold text-slate-900 mb-8 uppercase tracking-tight leading-tight" data-i18n-html="brd_spec_title">
                    Technical <br /> Surveillance <span class="text-blue-600">Specs</span>
                </h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
                    <div class="group">
                        <div class="w-12 h-12 bg-white rounded-xl shadow-sm border border-slate-100 flex items-center justify-center mb-4 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300"><Shield size={24} /></div>
                        <h4 class="text-sm font-bold text-slate-900 uppercase tracking-tight mb-2" data-i18n="brd_spec1_title">Perimeter Stealth</h4>
                        <p class="text-slate-500 text-xs leading-relaxed" data-i18n="brd_spec1_desc">Low-acoustic signature and specialized coatings for discreet tactical observation.</p>
                    </div>
                    <div class="group">
                        <div class="w-12 h-12 bg-white rounded-xl shadow-sm border border-slate-100 flex items-center justify-center mb-4 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300"><Radio size={24} /></div>
                        <h4 class="text-sm font-bold text-slate-900 uppercase tracking-tight mb-2" data-i18n="brd_spec2_title">Radar-AI Fusion</h4>
                        <p class="text-slate-500 text-xs leading-relaxed" data-i18n="brd_spec2_desc">Seamless integration with ground-based radar systems for cross-cueing identification.</p>
                    </div>
                    <div class="group">
                        <div class="w-12 h-12 bg-white rounded-xl shadow-sm border border-slate-100 flex items-center justify-center mb-4 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300"><Gauge size={24} /></div>
                        <h4 class="text-sm font-bold text-slate-900 uppercase tracking-tight mb-2" data-i18n="brd_spec3_title">Endurance Ops</h4>
                        <p class="text-slate-500 text-xs leading-relaxed" data-i18n="brd_spec3_desc">Up to 8 hours of continuous regional surveillance with rapid hybrid recharging.</p>
                    </div>
                    <div class="group">
                        <div class="w-12 h-12 bg-white rounded-xl shadow-sm border border-slate-100 flex items-center justify-center mb-4 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300"><Cpu size={24} /></div>
                        <h4 class="text-sm font-bold text-slate-900 uppercase tracking-tight mb-2" data-i18n="brd_spec4_title">Edge Processing</h4>
                        <p class="text-slate-500 text-xs leading-relaxed" data-i18n="brd_spec4_desc">On-board autonomous navigation and threat classification without satellite dependency.</p>
                    </div>
                </div>
            </div>

            <div class="relative lg:ml-auto">
                <!-- Decorative Ring -->
                <div
                    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] border border-blue-600/10 rounded-full animate-spin-slow"
                >
                </div>

                <div
                    class="relative z-10 rounded-[40px] overflow-hidden shadow-2xl border-4 border-blue-600/20 aspect-[15/10]"
                >
                    <img
                        src="/assets/bordersol.jpg"
                        alt="Autonomous Border Surveillance Intelligence"
                        class="w-full h-full object-cover transform hover:scale-105 transition-transform duration-700"
                    />

                    <!-- HUD Overlays -->
                    <div
                        class="absolute top-8 left-8 p-4 bg-slate-900/80 backdrop-blur-md rounded-2xl border border-white/10"
                    >
                        <div class="flex items-center gap-3 mb-2">
                            <div
                                class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"
                            >
                            </div>
                            <span
                                class="text-white text-[10px] font-bold uppercase tracking-widest"
                                >Active Tracking</span
                            >
                        </div>
                        <p
                            class="text-slate-400 text-[9px] font-medium leading-tight"
                        >
                            Vessel ID: K-8290<br />Range: 12.4km
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes spin-slow {
        from {
            transform: translate(-50%, -50%) rotate(0deg);
        }
        to {
            transform: translate(-50%, -50%) rotate(360deg);
        }
    }
    .animate-spin-slow {
        animation: spin-slow 20s linear infinite;
    }
</style>

<section class="py-12 px-4 md:px-8 bg-slate-50 overflow-hidden" id="dashboard">
    <div class="max-w-screen-2xl mx-auto text-center mb-8 px-4">
        <h2
            class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 uppercase tracking-tight"
         data-i18n="pipe_dash_title">
            Full Dashboard Integration
        </h2>
        <p class="text-slate-500 max-w-2xl mx-auto text-lg leading-relaxed" data-i18n="pipe_dash_desc">
            Visualize your entire pipeline network on a single interface. Access
            live feeds, historical data, and maintenance alerts from any device.
            Below you can see the demo of the Software
        </p>
    </div>

    <div class="max-w-screen-2xl mx-auto relative group">
        <!-- Dashboard UI Container -->
        <div
            class="relative rounded-[32px] overflow-hidden shadow-5xl bg-[#05070A] border border-white/10 h-[800px] flex"
        >
            <!-- Sidebar -->
            <aside
                class="w-64 hidden lg:flex flex-col bg-[#05070A] border-r border-white/5 text-white z-30"
            >
                <div class="p-8 flex items-center gap-3">
                    <div
                        class="w-10 h-10 rounded-xl bg-[#0066FF] flex items-center justify-center shadow-lg shadow-blue-500/30"
                    >
                        <span
                            class="material-symbols-outlined text-white font-light"
                        ></span>
                    </div>
                    <div>
                        <h1
                            class="font-bold text-lg tracking-tight leading-none"
                        >
                            KAZDRONE
                        </h1>
                        <p
                            class="text-[10px] text-slate-400 font-bold uppercase tracking-widest mt-1"
                         data-i18n="dash_sidebar_solutions">
                            Solutions
                        </p>
                    </div>
                </div>
                <nav class="flex-1 px-4 py-4 space-y-1">
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl bg-[#0066FF] text-white font-medium transition-all shadow-lg shadow-blue-500/20"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >grid_view</span
                        >
                        <span class="text-sm" data-i18n="dash_sidebar_dashboard">Dashboard</span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >flight</span
                        >
                        <span class="text-sm" data-i18n="dash_sidebar_fleet">Fleet</span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >analytics</span
                        >
                        <span class="text-sm" data-i18n="dash_sidebar_analytics">Analytics</span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all relative cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >notifications</span
                        >
                        <span class="text-sm" data-i18n="dash_sidebar_alerts">Alerts</span>
                        <span
                            class="absolute right-4 top-1/2 -translate-y-1/2 w-2 h-2 bg-[#00D1FF] rounded-full shadow-[0_0_12px_rgba(0,209,255,0.5)]"
                        ></span>
                    </div>
                    <div
                        class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all cursor-default"
                    >
                        <span class="material-symbols-outlined text-[22px]"
                            >settings</span
                        >
                        <span class="text-sm" data-i18n="dash_sidebar_settings">Settings</span>
                    </div>
                </nav>
                <div class="p-6">
                    <button
                        class="w-full py-3.5 bg-[#0066FF] hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-500/25 transition-all flex items-center justify-center gap-2 text-sm uppercase tracking-wide"
                    >
                        <span class="material-symbols-outlined text-xl"
                            >add_circle</span
                        >
                        <span data-i18n="pipe_dash_new_mission">New Mission</span>
                    </button>
                </div>
            </aside>

            <!-- Main Content -->
            <main
                class="flex-1 flex flex-col relative overflow-hidden bg-white"
            >
                <header
                    class="h-16 border-b border-slate-200 bg-white/90 backdrop-blur-xl px-8 flex items-center justify-between z-20"
                >
                    <div class="flex items-center gap-8">
                        <h2
                            class="text-lg font-bold text-slate-800 tracking-tight"
                         data-i18n="pipe_dash_header_title">
                            AI Pipeline Inspection
                        </h2>
                        <div
                            class="flex items-center gap-2 px-3 py-1.5 bg-blue-50/50 text-[#0066FF] rounded-full border border-blue-100"
                        >
                            <span
                                class="w-1.5 h-1.5 bg-[#0066FF] rounded-full animate-pulse"
                            ></span>
                            <span
                                class="text-[10px] font-black uppercase tracking-widest"
                                 data-i18n="pipe_dash_sys_status">System Status: Active</span
                            >
                        </div>
                    </div>
                </header>

                <!-- Map Area -->
                <div class="flex-1 relative bg-slate-200 overflow-hidden">
                    <div
                        class="absolute inset-0 grayscale contrast-125 opacity-40"
                        style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDRPqhgOykyu6IDT0v4II37qQpiLxiRgE6ARl2dcnL0mjS-t8fSVrQUjy4F-XExDFyO-L6UQMexyLpUb1Fi19KEyMcnQkPzHp7z0dNZQKinON2CIqPvi3B-bw894tACkesHxRJ7GIBprrnpQNOCgy708G5cmDRlK6WLZNPDUyO6w2oa8ivOLSOBVxVcyYsMdASaWRsq9p4-HbmvsqRg87eEBx6GgWfenr9nHALbhPODjXY2WmrPYM-iz1xKzsvKwQr8t8OVm-dA5OQ'); background-size: cover;"
                    >
                    </div>

                    <svg
                        class="absolute inset-0 w-full h-full pointer-events-none opacity-80"
                        preserveAspectRatio="none"
                        viewBox="0 0 1000 1000"
                    >
                        <path
                            class="drop-shadow-[0_0_8px_rgba(0,102,255,0.5)]"
                            d="M-100,500 C100,450 300,550 500,500 S800,400 1100,450"
                            fill="none"
                            stroke="#0066FF"
                            stroke-dasharray="12 6"
                            stroke-width="4"></path>
                    </svg>

                    <!-- Markers -->
                    <div
                        class="absolute top-[48%] left-[40%] group/marker cursor-pointer"
                    >
                        <div class="relative flex items-center justify-center">
                            <div
                                class="absolute w-12 h-12 bg-[#0066FF] rounded-full opacity-20 animate-ping"
                            >
                            </div>
                            <div
                                class="relative w-5 h-5 bg-white rounded-full border-4 border-[#0066FF] shadow-2xl"
                            >
                            </div>
                            <div
                                class="absolute bottom-10 left-1/2 -translate-x-1/2 bg-white px-5 py-3 rounded-2xl shadow-2xl border border-slate-100 min-w-[220px] z-40 transition-all group-hover/marker:scale-105"
                            >
                                <p
                                    class="text-[10px] uppercase font-black text-[#0066FF] mb-1 flex items-center gap-1"
                                >
                                    <span
                                        class="material-symbols-outlined text-sm"
                                        >warning</span
                                     data-i18n="pipe_dash_crit_alert">
                                    Critical Detection
                                </p>
                                <p class="text-sm font-bold text-slate-800" data-i18n="pipe_dash_struct_damage">
                                    Structural Damage Detected
                                </p>
                                <div
                                    class="mt-2 pt-2 border-t border-slate-50 flex justify-between uppercase tracking-tighter"
                                >
                                    <p
                                        class="text-[10px] text-slate-400 font-bold"
                                     data-i18n="pipe_dash_node">
                                        Node: P-0421
                                    </p>
                                    <p
                                        class="text-[10px] text-[#0066FF] font-black"
                                     data-i18n="pipe_dash_conf">
                                        98.2% CONF.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- HUD Controls -->
                    <div class="absolute bottom-8 right-8 flex flex-col gap-2">
                        <button
                            class="w-12 h-12 bg-white rounded-xl shadow-xl border border-slate-100 flex items-center justify-center text-slate-600 hover:text-[#0066FF] transition-all"
                        >
                            <span class="material-symbols-outlined">add</span>
                        </button>
                        <button
                            class="w-12 h-12 bg-white rounded-xl shadow-xl border border-slate-100 flex items-center justify-center text-slate-600 hover:text-[#0066FF] transition-all"
                        >
                            <span class="material-symbols-outlined">remove</span
                            >
                        </button>
                    </div>

                    <div class="absolute top-8 left-8">
                        <div
                            class="bg-white/90 backdrop-blur-xl p-6 rounded-2xl shadow-2xl border border-white min-w-[260px]"
                        >
                            <p
                                class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3"
                             data-i18n="pipe_dash_scan_prog">
                                Live Scanning Progress
                            </p>
                            <div class="flex items-end gap-2 mb-4">
                                <span
                                    class="text-5xl font-black text-slate-800 leading-none"
                                    >142</span
                                >
                                <span
                                    class="text-sm text-slate-400 font-bold mb-1 uppercase tracking-tighter"
                                     data-i18n="pipe_dash_km_comp">KM COMPLETE</span
                                >
                            </div>
                            <div
                                class="w-full bg-slate-100 h-3 rounded-full overflow-hidden p-0.5"
                            >
                                <div
                                    class="bg-[#0066FF] h-full w-[65%] rounded-full shadow-[0_0_12px_rgba(0,102,255,0.4)] transition-all duration-1000"
                                >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Right Sidebar: Detection Feed -->
            <aside
                class="w-80 hidden xl:flex flex-col border-l border-slate-200 bg-white z-20"
            >
                <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                    <h3
                        class="font-extrabold text-slate-800 text-lg flex items-center gap-2"
                    >
                        <span class="material-symbols-outlined text-[#0066FF]"
                            >monitoring</span
                        >
                        <span data-i18n="pipe_dash_feed_title">AI Detection Feed</span>
                    </h3>
                    <p
                        class="text-[11px] text-slate-500 font-medium mt-1 uppercase tracking-tighter"
                     data-i18n="pipe_dash_feed_sub">
                        Real-time recognition
                    </p>
                </div>

                <div class="flex-1 overflow-y-auto p-4 space-y-4">
                    <!-- Feed Item 1 -->
                    <div
                        class="bg-white rounded-2xl p-4 border border-blue-200 shadow-sm group hover:shadow-xl hover:border-[#0066FF] transition-all duration-300"
                    >
                        <div
                            class="relative rounded-xl overflow-hidden aspect-video mb-4"
                        >
                            <img
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuAlPfzeenoLH17gvjgeir3j2yvP0rqGGlYvFcjlVRHrAnzB9mt_hPIaMfKEzMREkhWtOMbYyQAgy1EtQ0PfqwVAxnfOmlAVuX7RNwseZcwQZL1No9c8hmahoKm1PcswPFTkNqdCaKyJvIorldUNFeLlXZlRhd7MpF1Wr1TofsFGR4Vr1FutwVKjIUBF3Wq6uKdxzG3G7KFpn3lvK_uVg9aqBsHxXFVRJKWQjJYSwPSOYQEqir3fV6m2S0nKMq0a0Xh7GXkK6WqxiAs"
                                alt="Critical Damage"
                                class="w-full h-full object-cover"
                            />
                            <div
                                class="absolute top-2 left-2 px-2 py-1 bg-red-600 text-white text-[9px] font-black rounded uppercase tracking-widest shadow-lg"
                            >
                                <span data-i18n="pipe_dash_alert_crit">Critical Alert</span>
                            </div>
                        </div>
                        <div class="flex justify-between items-start">
                            <div>
                                <h4 class="text-sm font-bold text-slate-800" data-i18n="pipe_dash_frac">
                                    Structural Fracture
                                </h4>
                                <p
                                    class="text-[10px] text-slate-400 font-bold uppercase mt-0.5"
                                 data-i18n="pipe_dash_sec_4b">
                                    Sector 4-B • 08:21 AM
                                </p>
                            </div>
                            <div
                                class="bg-blue-50 px-2 py-1 rounded-lg border border-blue-100 text-[10px] font-black text-[#0066FF]"
                            >
                                98.2% CI
                            </div>
                        </div>
                    </div>

                    <!-- Feed Item 2 -->
                    <div
                        class="bg-white rounded-2xl p-4 border border-slate-100 shadow-sm group hover:shadow-xl hover:border-[#0066FF] transition-all duration-300 opacity-60"
                    >
                        <div
                            class="relative rounded-xl overflow-hidden aspect-video mb-4"
                        >
                            <img
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBlpU6MY6bV8X1HbsqVbd98B-_VRDKeCUtEeUDcKid1zZDOfPzrdMT0_qN1ded2xcwflxdTaBo_VNT-LuKLYaE7vxzwuoEHbVY1y03BjsL_ro_OAATpIgF5tU9kJjry0qPameaot1CusocA118I6yz0r4Q5WF0N1dyGAZf6kM6_haDmTuAg9VDVVJf_iRS4qDXhLVfNwSg3gn-ILD8kJ3UHVqUFz-UJrPphM5BhPYwoUMe7dyRYRUxi95zWGWUh6-x-gF5aut5N_aA"
                                alt="Valve Inspection"
                                class="w-full h-full object-cover"
                            />
                            <div
                                class="absolute top-2 left-2 px-2 py-1 bg-slate-800 text-white text-[9px] font-black rounded uppercase tracking-widest shadow-lg"
                            >
                                <span data-i18n="pipe_dash_observ">Observation</span>
                            </div>
                        </div>
                        <div class="flex justify-between items-start">
                            <div>
                                <h4
                                    class="text-sm font-bold text-slate-800 tracking-tight"
                                 data-i18n="pipe_dash_valve_check">
                                    Valve Erosion Check
                                </h4>
                                <p
                                    class="text-[10px] text-slate-400 font-bold uppercase mt-0.5"
                                 data-i18n="pipe_dash_sec_12a">
                                    Sector 12-A • 08:14 AM
                                </p>
                            </div>
                            <div
                                class="bg-slate-50 px-2 py-1 rounded-lg border border-slate-100 text-[10px] font-black text-slate-500"
                            >
                                74.5% CI
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer Telemetry -->
                <div class="p-6 bg-slate-50 border-t border-slate-100 mt-auto">
                    <div class="flex items-center justify-between mb-4">
                        <span
                            class="text-[10px] font-black text-slate-400 uppercase tracking-widest"
                             data-i18n="pipe_dash_telemetry">Live Telemetry</span
                        >
                        <div class="flex items-center gap-1.5">
                            <span
                                class="w-1.5 h-1.5 bg-[#00D1FF] rounded-full animate-pulse shadow-[0_0_8px_rgba(0,209,255,0.6)]"
                            ></span>
                            <span
                                class="text-[9px] font-bold text-[#0066FF] uppercase tracking-tighter"
                                 data-i18n="pipe_dash_linked">Linked</span
                            >
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-3">
                        <div
                            class="bg-white p-3 rounded-xl border border-slate-200 shadow-sm"
                        >
                            <p
                                class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1"
                             data-i18n="pipe_dash_drone_alt">
                                Drone Alt.
                            </p>
                            <p
                                class="text-xl font-black text-slate-800 leading-none"
                            >
                                120<span
                                    class="text-xs text-slate-400 font-medium ml-0.5"
                                    >m</span
                                >
                            </p>
                        </div>
                        <div
                            class="bg-white p-3 rounded-xl border border-slate-200 shadow-sm"
                        >
                            <p
                                class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1"
                             data-i18n="pipe_dash_wind_spd">
                                Wind Spd.
                            </p>
                            <p
                                class="text-xl font-black text-slate-800 leading-none"
                            >
                                12<span
                                    class="text-xs text-slate-400 font-medium ml-0.5"
                                    >km/h</span
                                >
                            </p>
                        </div>
                    </div>
                </div>
            </aside>
        </div>

        <!-- External Glow -->
        <div
            class="absolute -inset-10 bg-blue-500/10 blur-[100px] -z-10 group-hover:bg-blue-500/20 transition-colors duration-1000"
        >
        </div>
    </div>
</section>

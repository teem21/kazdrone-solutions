---
import { ArrowRight } from "lucide-astro";
---

<section id="solutions" class="py-8 bg-white">
    <div class="max-w-screen-2xl mx-auto px-4 md:px-8">
        <div class="text-center mb-10">
            <p class="text-slate-400 text-sm font-bold uppercase tracking-widest mb-4" data-i18n="sol_label">Our Portfolio</p>
            <h2 class="text-4xl md:text-5xl font-black text-slate-900 uppercase tracking-tight" data-i18n-html="sol_title">
                Select Your <span class="text-blue-600">Mission</span>
            </h2>
        </div>

        <div class="space-y-6">
            <!-- Wildfire -->
            <a href="/wildfire-solution"
                class="group relative block w-full rounded-[24px] overflow-hidden shadow-2xl bg-slate-900 h-[440px] md:h-[520px] focus:outline-none focus:ring-4 focus:ring-blue-500/50 transition-all hover:scale-[1.01] hover:shadow-[0_30px_80px_rgba(0,0,0,0.5)]">
                <div class="absolute inset-0 z-0">
                    <img src="/assets/firefightinghero.jpg" alt="Wildfire" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="opacity:0.6" />
                    <div class="absolute inset-0 bg-gradient-to-r from-slate-950/90 via-slate-950/70 to-transparent"></div>
                    <div class="absolute inset-0 bg-orange-950/20"></div>
                    <div class="absolute inset-0 bg-slate-950/0 group-hover:bg-slate-950/10 transition-colors duration-300"></div>
                </div>
                <div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-14">
                    <div class="flex items-start justify-between">
                        <span class="inline-block px-4 py-1.5 rounded-full bg-orange-500/10 text-orange-400 text-sm font-bold tracking-wider uppercase border border-orange-500/20" data-i18n="sol_wf_label">Nature Protection</span>
                        <div class="w-12 h-12 rounded-full bg-white/10 border border-white/20 flex items-center justify-center backdrop-blur-sm group-hover:bg-white/20 transition-all">
                            <ArrowRight class="text-white transition-transform group-hover:translate-x-0.5" size={20} />
                        </div>
                    </div>
                    <div>
                        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white mb-5 leading-[1.05] uppercase" data-i18n-html="sol_wf_title">
                            Autonomous <span class="text-orange-500">Wildfire Monitoring</span>
                        </h2>
                        <p class="text-base md:text-lg text-slate-300 max-w-2xl leading-relaxed" data-i18n="sol_wf_desc">Detect ignition points, track fire fronts in real-time, and coordinate emergency response with AI-powered aerial surveillance. Protect nature from fire.</p>
                    </div>
                </div>
            </a>

            <!-- Border -->
            <a href="/border-solution"
                class="group relative block w-full rounded-[24px] overflow-hidden shadow-2xl bg-slate-900 h-[440px] md:h-[520px] focus:outline-none focus:ring-4 focus:ring-blue-500/50 transition-all hover:scale-[1.01] hover:shadow-[0_30px_80px_rgba(0,0,0,0.5)]">
                <div class="absolute inset-0 z-0">
                    <img src="/assets/borderhero.jpg" alt="Border" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="opacity:0.8" />
                    <div class="absolute inset-0 bg-gradient-to-r from-slate-950/70 via-slate-950/70 to-transparent"></div>
                    <div class="absolute inset-0 bg-blue-950/5"></div>
                    <div class="absolute inset-0 bg-slate-950/0 group-hover:bg-slate-950/10 transition-colors duration-300"></div>
                </div>
                <div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-14">
                    <div class="flex items-start justify-between">
                        <span class="inline-block px-4 py-1.5 rounded-full bg-orange-500/10 text-orange-400 text-sm font-bold tracking-wider uppercase border border-orange-500/20" data-i18n="sol_brd_label">National Security</span>
                        <div class="w-12 h-12 rounded-full bg-white/10 border border-white/20 flex items-center justify-center backdrop-blur-sm group-hover:bg-white/20 transition-all">
                            <ArrowRight class="text-white transition-transform group-hover:translate-x-0.5" size={20} />
                        </div>
                    </div>
                    <div>
                        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white mb-5 leading-[1.05] uppercase" data-i18n-html="sol_brd_title">
                            Autonomous <span class="text-orange-500">Border Integrity</span>
                        </h2>
                        <p class="text-base md:text-lg text-slate-300 max-w-2xl leading-relaxed" data-i18n="sol_brd_desc">Secure vast perimeters with AI-powered aerial patrols. Detect unauthorized crossings, track movement in difficult terrain, and coordinate rapid response with zero detection gaps.</p>
                    </div>
                </div>
            </a>

            <!-- Pipeline -->
            <a href="/pipeline-solution"
                class="group relative block w-full rounded-[24px] overflow-hidden shadow-2xl bg-slate-900 h-[440px] md:h-[520px] focus:outline-none focus:ring-4 focus:ring-blue-500/50 transition-all hover:scale-[1.01] hover:shadow-[0_30px_80px_rgba(0,0,0,0.5)]">
                <div class="absolute inset-0 z-0">
                    <img src="/assets/pipelinehero.jpg" alt="Pipeline" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="opacity:0.8" />
                    <div class="absolute inset-0 bg-gradient-to-r from-slate-950/90 via-slate-950/40 to-transparent"></div>
                    <div class="absolute inset-0 bg-slate-950/10"></div>
                    <div class="absolute inset-0 bg-slate-950/0 group-hover:bg-slate-950/10 transition-colors duration-300"></div>
                </div>
                <div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-14">
                    <div class="flex items-start justify-between">
                        <span class="inline-block px-4 py-1.5 rounded-full bg-blue-500/10 text-blue-400 text-sm font-bold tracking-wider uppercase border border-blue-500/20" data-i18n="sol_pipe_label">Industry Solution</span>
                        <div class="w-12 h-12 rounded-full bg-white/10 border border-white/20 flex items-center justify-center backdrop-blur-sm group-hover:bg-white/20 transition-all">
                            <ArrowRight class="text-white transition-transform group-hover:translate-x-0.5" size={20} />
                        </div>
                    </div>
                    <div>
                        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white mb-5 leading-[1.05] uppercase" data-i18n-html="sol_pipe_title">
                            AI-Powered <span class="text-blue-500">Pipeline Inspection</span>
                        </h2>
                        <p class="text-base md:text-lg text-slate-300 max-w-2xl leading-relaxed" data-i18n="sol_pipe_desc">Set up a system that detects leaks, corrosion, and structural anomalies with unmatched precision and safety. Connect data from drone to your ERP and get real-time visualization.</p>
                    </div>
                </div>
            </a>

            <!-- Grid -->
            <a href="/grid-solution"
                class="group relative block w-full rounded-[24px] overflow-hidden shadow-2xl bg-slate-900 h-[440px] md:h-[520px] focus:outline-none focus:ring-4 focus:ring-blue-500/50 transition-all hover:scale-[1.01] hover:shadow-[0_30px_80px_rgba(0,0,0,0.5)]">
                <div class="absolute inset-0 z-0">
                    <img src="/assets/herostation.jpg" alt="Grid" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" style="opacity:0.8" />
                    <div class="absolute inset-0 bg-gradient-to-r from-slate-950/90 via-slate-950/40 to-transparent"></div>
                    <div class="absolute inset-0 bg-slate-950/10"></div>
                    <div class="absolute inset-0 bg-slate-950/0 group-hover:bg-slate-950/10 transition-colors duration-300"></div>
                </div>
                <div class="relative z-10 h-full flex flex-col justify-between p-8 md:p-14">
                    <div class="flex items-start justify-between">
                        <span class="inline-block px-4 py-1.5 rounded-full bg-blue-500/10 text-blue-400 text-sm font-bold tracking-wider uppercase border border-blue-500/20" data-i18n="sol_grid_label">Grid Infrastructure</span>
                        <div class="w-12 h-12 rounded-full bg-white/10 border border-white/20 flex items-center justify-center backdrop-blur-sm group-hover:bg-white/20 transition-all">
                            <ArrowRight class="text-white transition-transform group-hover:translate-x-0.5" size={20} />
                        </div>
                    </div>
                    <div>
                        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white mb-5 leading-[1.05] uppercase" data-i18n-html="sol_grid_title">
                            AI-Powered <span class="text-blue-500">Substation Inspection</span>
                        </h2>
                        <p class="text-base md:text-lg text-slate-300 max-w-2xl leading-relaxed" data-i18n="sol_grid_desc">Revolutionize grid reliability with autonomous drone thermal and visual inspections. Ensure uninterrupted power delivery through high-frequency, safe monitoring.</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</section>

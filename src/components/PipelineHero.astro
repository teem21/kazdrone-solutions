---
import { Calendar } from "lucide-astro";
---

<section class="bg-white py-4 px-4 md:px-8">
    <div
        class="max-w-screen-2xl mx-auto relative rounded-[24px] overflow-hidden shadow-2xl bg-slate-900 pt-12 pb-10 md:pt-16 md:pb-12 px-8 md:px-20"
    >
        <!-- Background Layer (Clipped inside card) -->
        <div class="absolute inset-0 z-0">
            <img
                src="/assets/pipelinehero.jpg"
                alt="Pipeline Inspection Background"
                class="w-full h-full object-cover opacity-100"
            />
            <div
                class="absolute inset-0 bg-gradient-to-r from-slate-950/90 via-slate-950/40 to-transparent"
            >
            </div>
            <div class="absolute inset-0 bg-slate-950/10"></div>
        </div>

        <!-- Content Layer -->
        <div
            class="relative z-10 flex flex-col md:flex-row items-center gap-16"
        >
            <div class="flex-1 text-center md:text-left">
                <span
                    class="inline-block px-4 py-1.5 rounded-full bg-blue-500/10 text-blue-400 text-sm font-bold tracking-wider uppercase mb-8 border border-blue-500/20"
                >
                    Industry Solution
                </span>
                <h1
                    class="text-5xl md:text-7xl font-bold tracking-tight text-white mb-8 leading-[1.1] uppercase"
                >
                    AI-Powered <br />
                    <span class="text-blue-500">Pipeline Inspection</span>
                </h1>
                <p
                    class="text-lg md:text-xl text-slate-300 mb-12 leading-relaxed max-w-2xl mx-auto md:mx-0"
                >
                    Set up a system that: detects leaks, corrosion, and
                    structural anomalies with <span class="text-white font-bold"
                        >unmatched precision</span
                    > and safety.
                    <br /><br />
                    Connect data from drone to your ERP and get real time data visualization
                    in Dashboard.
                </p>

                <div
                    class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start"
                >
                    <button
                        data-popup="contact"
                        class="group relative px-10 py-5 bg-blue-600 text-white rounded-full font-bold transition-all hover:bg-blue-700 hover:scale-105 active:scale-95 shadow-lg shadow-blue-500/25 flex items-center justify-center gap-3"
                    >
                        <span>BOOK A CONSULTATION</span>
                        <Calendar size={20} />
                    </button>
                </div>
            </div>

            <!-- Float UI Elements Placeholder or empty div to balance the flex -->
            <div class="flex-1 hidden md:block"></div>
        </div>
    </div>
</section>

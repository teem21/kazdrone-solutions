---
import { Calendar } from "lucide-astro";
---

<section class="py-12 px-4 md:px-8">
    <div class="max-w-screen-2xl mx-auto rounded-[40px] bg-slate-950 p-12 md:p-24 relative overflow-hidden group shadow-2xl shadow-blue-500/10">
        <div class="absolute top-0 right-0 w-1/2 h-full bg-blue-600/10 blur-[120px] -z-0 translate-x-1/2 group-hover:bg-blue-600/20 transition-colors duration-1000"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-12">
            <div class="max-w-2xl text-center md:text-left">
                <h2 class="text-4xl md:text-6xl font-bold text-white mb-8 tracking-tight uppercase leading-tight" data-i18n-html="wf_cta_title">
                    Modernize Your <br /><span class="text-blue-500">Fire Management</span>
                </h2>
                <p class="text-slate-400 text-lg md:text-xl leading-relaxed" data-i18n="wf_cta_desc">Connect with our public safety experts to deploy autonomous wildfire monitoring solutions for your region. Protect your community with advanced intelligence.</p>
            </div>
            <div class="flex-shrink-0">
                <button data-popup="contact" class="px-12 py-5 bg-white text-slate-950 rounded-full font-black text-lg transition-all hover:bg-blue-600 hover:text-white hover:scale-110 active:scale-95 shadow-2xl shadow-white/5 group-hover:shadow-blue-600/20 flex items-center gap-3">
                    <span data-i18n="wf_cta_btn">CONTACT US</span>
                    <Calendar size={20} />
                </button>
            </div>
        </div>
    </div>
</section>

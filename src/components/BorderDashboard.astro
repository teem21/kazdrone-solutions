---
import {
    Shield,
    LayoutGrid,
    MapPin,
    Plane,
    Bell,
    Terminal,
    Activity,
    Wifi,
    Zap,
} from "lucide-astro";
---

<section class="py-20 px-4 md:px-8 bg-slate-50 overflow-hidden" id="dashboard">
    <div class="max-w-screen-2xl mx-auto text-center mb-12 px-4">
        <h2
            class="text-4xl md:text-6xl font-black text-slate-900 mb-6 uppercase tracking-tight"
         data-i18n="brd_dash_title">
            Tactical <span class="text-blue-600">Border Overwatch</span>
        </h2>
        <p
            class="text-slate-500 max-w-3xl mx-auto text-xl leading-relaxed font-medium"
         data-i18n="brd_dash_desc">
            Deploy national-scale autonomous security. Unify regional
            surveillance streams, track thermal signatures, and coordinate
            intercept flights from a single tactical interface.
        </p>
    </div>

    <!-- Dashboard Container -->
    <div class="max-w-screen-2xl mx-auto relative">
        <div
            class="dashboard-wrapper rounded-[32px] overflow-hidden shadow-5xl border border-slate-900/10 bg-[#1A1C20] h-[850px] flex flex-col font-mono text-[#E0E4E8]"
        >
            <!-- Top Navigation Bar -->
            <header
                class="h-16 border-b border-[#374151] bg-[#1A1C20] shrink-0 flex items-center justify-between px-6 z-20 relative"
            >
                <div class="flex items-center gap-6">
                    <div class="flex items-center gap-3">
                        <Zap class="text-blue-500" size={24} />
                        <div>
                            <h1
                                class="font-bold text-lg tracking-wider leading-none uppercase"
                            >
                                <span data-i18n="brd_dash_cmd">Border CMD</span> <span
                                    class="text-[#6B7280] font-normal">//</span
                                > <span data-i18n="brd_dash_sector7">SECTOR 7</span>
                            </h1>
                            <div class="flex items-center gap-2 mt-0.5">
                                <div
                                    class="w-1.5 h-1.5 rounded-full bg-[#34D399] animate-pulse"
                                >
                                </div>
                                <span
                                    class="text-[10px] text-[#6B7280] tracking-widest font-bold"
                                     data-i18n="brd_dash_uplink">UPLINK STABLE (24ms)</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-6">
                    <div
                        class="hidden md:flex items-center gap-4 bg-[#25282E] px-4 py-1.5 border border-[#374151] clip-chamfer-sm"
                    >
                        <Activity size={14} class="text-[#6B7280]" />
                        <span class="text-lg font-bold">14:32:09 UTC</span>
                    </div>
                    <div class="flex gap-3">
                        <button
                            class="flex items-center gap-2 px-5 py-2 bg-[#25282E] border border-[#374151] hover:bg-[#2E323A] transition-all clip-chamfer-sm text-sm font-bold"
                        >
                            <Wifi size={14} class="text-[#00E0FF]" />
                            <span data-i18n="brd_dash_network">NETWORK</span>
                        </button>
                        <button
                            class="group relative flex items-center gap-2 px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold tracking-widest transition-all clip-chamfer-sm shadow-[0_0_15px_rgba(37,99,235,0.3)]"
                        >
                            <div
                                class="w-2 h-2 bg-white rounded-full animate-pulse mr-1"
                            >
                            </div>
                            <span data-i18n="brd_dash_estop">ESTOP</span>
                        </button>
                    </div>
                </div>
            </header>

            <!-- Main Content Area -->
            <div class="flex flex-1 overflow-hidden relative">
                <!-- Left Sidebar: Unit List -->
                <aside
                    class="w-[300px] bg-[#1A1C20] border-r border-[#374151] hidden lg:flex flex-col z-10 shrink-0"
                >
                    <div class="p-4 border-b border-[#374151] bg-[#25282E]/50">
                        <div class="flex justify-between items-center mb-4">
                            <h2
                                class="text-[10px] font-bold text-[#6B7280] tracking-widest uppercase"
                            >
                                <span data-i18n="brd_dash_act_units">Active Units</span>
                            </h2>
                            <span
                                class="px-2 py-0.5 bg-blue-600/20 text-blue-400 text-[10px] font-bold border border-blue-500/30"
                                ><span data-i18n="brd_dash_online">4 ONLINE</span></span
                            >
                        </div>
                        <div class="flex gap-1">
                            <button
                                class="flex-1 py-2 text-[10px] font-bold bg-blue-600 text-white rounded-sm"
                                ><span data-i18n="brd_dash_all">ALL</span></button
                            >
                            <button
                                class="flex-1 py-2 text-[10px] font-bold bg-[#25282E] border border-[#374151] text-[#6B7280] rounded-sm hover:text-white transition-colors"
                                ><span data-i18n="brd_dash_air">AIR</span></button
                            >
                            <button
                                class="flex-1 py-2 text-[10px] font-bold bg-[#25282E] border border-[#374151] text-[#6B7280] rounded-sm hover:text-white transition-colors"
                                ><span data-i18n="brd_dash_gnd">GND</span></button
                            >
                        </div>
                    </div>

                    <div
                        class="flex-1 overflow-y-auto p-4 space-y-3 custom-scrollbar"
                    >
                        <!-- Unit Card 1 -->
                        <div
                            class="bg-[#25282E] border-l-4 border-l-[#34D399] border-y border-r border-[#374151] p-3 hover:bg-[#2E323A] transition-all clip-chamfer-sm group cursor-pointer"
                        >
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <div class="flex items-center gap-2">
                                        <h3
                                            class="font-bold text-base leading-none"
                                        >
                                            DR-01
                                        </h3>
                                        <Plane
                                            size={14}
                                            class="text-[#00E0FF]"
                                        />
                                    </div>
                                    <p
                                        class="text-[10px] text-[#6B7280] font-bold mt-1 uppercase tracking-tight"
                                    >
                                        <span data-i18n="brd_dash_survey">Surveying // Sector 7</span>
                                    </p>
                                </div>
                                <div class="text-right">
                                    <span
                                        class="text-[10px] text-[#34D399] font-bold block"
                                         data-i18n="brd_dash_active">ACTIVE</span
                                    >
                                    <span class="text-[9px] text-[#6B7280]"
                                         data-i18n="brd_dash_alt_120" data-i18n="brd_dash_alt_120">ALT: 120m</span
                                    >
                                </div>
                            </div>
                            <div class="flex items-center gap-4 mt-3">
                                <div class="flex-1">
                                    <div
                                        class="flex justify-between text-[9px] text-[#6B7280] mb-1 font-bold"
                                    >
                                        <span data-i18n="brd_dash_batt">BATT</span>
                                        <span class="text-white">86%</span>
                                    </div>
                                    <div class="flex gap-0.5 h-1">
                                        <div class="flex-1 bg-[#34D399]"></div>
                                        <div class="flex-1 bg-[#34D399]"></div>
                                        <div class="flex-1 bg-[#34D399]"></div>
                                        <div class="flex-1 bg-[#34D399]"></div>
                                        <div class="flex-1 bg-[#34D399]"></div>
                                        <div class="flex-1 bg-[#374151]"></div>
                                    </div>
                                </div>
                                <div class="flex flex-col items-center">
                                    <Activity
                                        size={12}
                                        class="text-[#34D399]"
                                    />
                                    <span
                                        class="text-[9px] text-[#6B7280] mt-0.5"
                                        >-42dB</span
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Unit Card 2 -->
                        <div
                            class="bg-[#25282E] border-l-4 border-l-orange-500 border-y border-r border-[#374151] p-3 hover:bg-[#2E323A] transition-all clip-chamfer-sm group cursor-pointer"
                        >
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <div class="flex items-center gap-2">
                                        <h3
                                            class="font-bold text-base leading-none"
                                        >
                                            DR-04
                                        </h3>
                                        <Bell
                                            size={14}
                                            class="text-orange-500"
                                        />
                                    </div>
                                    <p
                                        class="text-[10px] text-orange-500 font-bold mt-1 uppercase tracking-tight"
                                    >
                                        <span data-i18n="brd_dash_rth">RTH // LOW BATT</span>
                                    </p>
                                </div>
                                <div class="text-right">
                                    <span
                                        class="text-[10px] text-orange-500 font-bold block animate-pulse"
                                         data-i18n="brd_dash_warning">WARNING</span
                                    >
                                    <span class="text-[9px] text-[#6B7280]"
                                         data-i18n="brd_dash_alt_85" data-i18n="brd_dash_alt_85">ALT: 85m</span
                                    >
                                </div>
                            </div>
                            <div class="flex items-center gap-4 mt-3">
                                <div class="flex-1">
                                    <div
                                        class="flex justify-between text-[9px] text-[#6B7280] mb-1 font-bold"
                                    >
                                        <span data-i18n="brd_dash_batt">BATT</span>
                                        <span class="text-orange-500">18%</span>
                                    </div>
                                    <div class="flex gap-0.5 h-1">
                                        <div class="flex-1 bg-orange-500"></div>
                                        <div class="flex-1 bg-[#374151]"></div>
                                        <div class="flex-1 bg-[#374151]"></div>
                                        <div class="flex-1 bg-[#374151]"></div>
                                        <div class="flex-1 bg-[#374151]"></div>
                                        <div class="flex-1 bg-[#374151]"></div>
                                    </div>
                                </div>
                                <div class="flex flex-col items-center">
                                    <Activity
                                        size={12}
                                        class="text-orange-500"
                                    />
                                    <span
                                        class="text-[9px] text-[#6B7280] mt-0.5"
                                        >-68dB</span
                                    >
                                </div>
                            </div>
                        </div>

                        <!-- Unit Card 3 -->
                        <div
                            class="bg-[#25282E] border-l-4 border-l-[#6B7280] border-y border-r border-[#374151] p-3 opacity-60 hover:opacity-100 transition-all clip-chamfer-sm group cursor-pointer"
                        >
                            <div class="flex items-center justify-between">
                                <h3 class="font-bold text-base">DR-07</h3>
                                <span
                                    class="text-[10px] font-bold text-[#6B7280]"
                                     data-i18n="brd_dash_stat" data-i18n="brd_dash_stat">STATIONARY</span
                                >
                            </div>
                            <div
                                class="mt-2 text-[9px] text-[#6B7280] flex justify-between uppercase"
                            >
                                <span data-i18n="brd_dash_diag_ok">Diagnostics: OK</span>
                                <span data-i18n="brd_dash_pad">Pad: A-1</span>
                            </div>
                        </div>
                    </div>

                    <div class="p-4 border-t border-[#374151]">
                        <button
                            class="w-full py-2.5 bg-transparent border border-dashed border-[#6B7280] text-[#6B7280] hover:border-blue-500 hover:text-blue-400 transition-all flex items-center justify-center gap-2 text-[10px] font-bold uppercase tracking-wider"
                        >
                            <LayoutGrid size={14} />
                            <span data-i18n="brd_dash_reg_unit">Register Unit</span>
                        </button>
                    </div>
                </aside>

                <!-- Center: Tactical Map Interface -->
                <section
                    class="flex-1 relative bg-[#0f1115] overflow-hidden group"
                >
                    <!-- Map Underlay -->
                    <div class="absolute inset-0 opacity-40 mix-blend-overlay">
                        <img
                            src="/assets/image.png"
                            alt="Tactical Map"
                            class="w-full h-full object-cover grayscale brightness-50 contrast-125"
                        />
                    </div>

                    <!-- Scanlines Overlay -->
                    <div
                        class="absolute inset-0 scanlines pointer-events-none opacity-20 z-10"
                    >
                    </div>

                    <!-- Map Decoration -->
                    <div class="absolute inset-0 map-grid z-0"></div>

                    <!-- Sector Info -->
                    <div class="absolute top-6 left-6 z-30 flex flex-col gap-2">
                        <div
                            class="bg-[#1A1C20]/80 backdrop-blur-md border border-[#374151] p-3 clip-chamfer-sm"
                        >
                            <span
                                class="text-[10px] font-bold text-[#6B7280] tracking-widest uppercase block mb-1"
                                 data-i18n="brd_dash_sector_lbl">Sector</span
                            >
                            <p class="text-lg font-bold" data-i18n="brd_dash_sector_val">07-ALPHA</p>
                        </div>
                        <div
                            class="bg-[#1A1C20]/80 backdrop-blur-md border border-[#374151] p-3 clip-chamfer-sm"
                        >
                            <span
                                class="text-[10px] font-bold text-[#6B7280] tracking-widest uppercase block mb-1"
                                 data-i18n="brd_dash_wind_lbl">Wind</span
                            >
                            <div class="flex items-center gap-2">
                                <Plane
                                    class="text-[#00E0FF] rotate-45"
                                    size={14}
                                />
                                <p class="text-sm font-bold" data-i18n="brd_dash_wind_val">12 KTS / NW</p>
                            </div>
                        </div>
                    </div>

                    <!-- Map Interaction Placeholder -->
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 flex flex-col items-center"
                    >
                        <div class="relative">
                            <div
                                class="w-24 h-24 rounded-full border border-blue-500/30 bg-blue-500/10 animate-ping absolute -translate-x-1/2 -translate-y-1/2 left-1/2 top-1/2"
                            >
                            </div>
                            <div
                                class="relative w-12 h-12 flex items-center justify-center"
                            >
                                <div
                                    class="w-4 h-4 bg-blue-500 rounded-full shadow-[0_0_15px_rgba(59,130,246,0.8)]"
                                >
                                </div>
                                <div
                                    class="absolute -bottom-8 bg-blue-600 text-[10px] font-bold px-2 py-0.5 rounded-sm whitespace-nowrap"
                                >
                                    <span data-i18n="brd_dash_dr01_act">DR-01 ACTIVE</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Geofence Labels -->
                    <div
                        class="absolute top-1/4 right-[20%] pointer-events-none"
                    >
                        <div
                            class="border border-blue-500/40 border-dashed p-10 bg-blue-500/5 clip-chamfer"
                        >
                            <span
                                class="text-[12px] font-bold text-blue-500/70 tracking-widest uppercase"
                                 data-i18n="brd_dash_nfz">No-Fly Zone // Alpha-Prime</span
                            >
                        </div>
                    </div>

                    <!-- Map Controls -->
                    <div
                        class="absolute bottom-8 right-8 z-30 flex flex-col gap-2"
                    >
                        <button
                            class="w-10 h-10 bg-[#25282E] border border-[#374151] flex items-center justify-center hover:bg-[#2E323A] transition-all clip-chamfer-sm"
                        >
                            <span class="text-xl">+</span>
                        </button>
                        <button
                            class="w-10 h-10 bg-[#25282E] border border-[#374151] flex items-center justify-center hover:bg-[#2E323A] transition-all clip-chamfer-sm"
                        >
                            <span class="text-xl">-</span>
                        </button>
                        <button
                            class="w-10 h-10 bg-[#25282E] border border-[#374151] text-[#00E0FF] flex items-center justify-center hover:bg-[#2E323A] transition-all clip-chamfer-sm mt-2"
                        >
                            <MapPin size={18} />
                        </button>
                    </div>
                </section>

                <!-- Right Sidebar: Alerts & Logs -->
                <aside
                    class="w-[340px] bg-[#1A1C20] border-l border-[#374151] hidden xl:flex flex-col z-10 shrink-0"
                >
                    <div
                        class="p-4 border-b border-[#374151] bg-[#25282E]/50 flex justify-between items-center"
                    >
                        <h2
                            class="text-[10px] font-bold text-[#6B7280] tracking-widest flex items-center gap-2 uppercase"
                        >
                            <Bell
                                size={12}
                                class="text-blue-500 animate-pulse"
                            />
                            <span data-i18n="brd_dash_sys_log">System Log</span>
                        </h2>
                        <button
                            class="text-[9px] font-bold text-[#6B7280] hover:text-white uppercase transition-colors"
                             data-i18n="brd_dash_clear">Clear</button
                        >
                    </div>

                    <div class="flex-1 overflow-y-auto custom-scrollbar">
                        <!-- Log Entry 1 -->
                        <div
                            class="p-3 border-b border-[#374151]/50 hover:bg-[#25282E]/40 transition-colors flex gap-3"
                        >
                            <span
                                class="text-[10px] text-[#6B7280] whitespace-nowrap"
                                >14:32:05</span
                            >
                            <div class="flex flex-col gap-0.5">
                                <span
                                    class="text-blue-500 font-bold text-[10px]"
                                     data-i18n="brd_dash_log1_sys" data-i18n="brd_dash_log1_sys">SYS</span
                                >
                                <p
                                    class="text-[11px] text-[#E0E4E8] leading-tight"
                                >
                                    <span data-i18n="brd_dash_log1_msg">Geofence definitions updated to
                                    v4.2.1-stable. All units synced.</span>
                                </p>
                            </div>
                        </div>

                        <!-- Log Entry 2 -->
                        <div
                            class="p-3 border-b border-[#374151]/50 hover:bg-[#25282E]/40 transition-colors flex gap-3"
                        >
                            <span
                                class="text-[10px] text-[#6B7280] whitespace-nowrap"
                                >14:31:42</span
                            >
                            <div class="flex flex-col gap-0.5">
                                <span
                                    class="text-blue-400 font-bold text-[10px]"
                                    >DR-01</span
                                >
                                <p
                                    class="text-[11px] text-[#E0E4E8] leading-tight"
                                >
                                    <span data-i18n="brd_dash_log2_msg">Reached Waypoint BRAVO. Initiating sector
                                    wide thermal sweep.</span>
                                </p>
                            </div>
                        </div>

                        <!-- Log Entry 3 (Warning) -->
                        <div
                            class="p-3 border-b border-orange-500/20 bg-orange-500/5 hover:bg-orange-500/10 transition-colors flex gap-3 border-l-2 border-l-orange-500"
                        >
                            <span
                                class="text-[10px] text-[#6B7280] whitespace-nowrap"
                                >14:30:15</span
                            >
                            <div class="flex flex-col gap-0.5">
                                <span
                                    class="text-orange-500 font-bold text-[10px]"
                                    >DR-04</span
                                >
                                <p
                                    class="text-[11px] text-white leading-tight font-medium"
                                >
                                    <span data-i18n="brd_dash_log3_msg">BATTERY CRITICAL. Initiating automatic
                                    Return-to-Home protocol.</span>
                                </p>
                            </div>
                        </div>

                        <!-- Log Entry 4 -->
                        <div
                            class="p-3 border-b border-[#374151]/50 hover:bg-[#25282E]/40 transition-colors flex gap-3"
                        >
                            <span
                                class="text-[10px] text-[#6B7280] whitespace-nowrap"
                                >14:28:00</span
                            >
                            <div class="flex flex-col gap-0.5">
                                <span
                                    class="text-blue-400 font-bold text-[10px]"
                                    >DR-07</span
                                >
                                <p
                                    class="text-[11px] text-[#E0E4E8] leading-tight"
                                >
                                    <span data-i18n="brd_dash_log4_msg">Unit safely docked at Hangar A. Commencing
                                    self-diagnostics.</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Console Input -->
                    <div class="p-4 bg-[#25282E] border-t border-[#374151]">
                        <div
                            class="flex items-center gap-2 bg-[#1A1C20] border border-[#374151] p-2.5 clip-chamfer-sm"
                        >
                            <Terminal size={14} class="text-[#6B7280]" />
                            <input
                                type="text"
                                data-i18n-placeholder="brd_dash_enter_cmd" placeholder="ENTER COMMAND..."
                                class="bg-transparent border-none text-[10px] font-bold text-white focus:ring-0 w-full placeholder:text-[#6B7280]/50 p-0 uppercase"
                            />
                        </div>
                    </div>
                </aside>
            </div>

            <!-- Dashboard Footer -->
            <footer
                class="h-8 bg-[#25282E] border-t border-[#374151] flex items-center justify-between px-6 text-[10px] font-bold text-[#6B7280] z-20"
            >
                <div class="flex gap-6 uppercase tracking-wider">
                    <span data-i18n="brd_dash_reg_eu">Region: EU-WEST-1</span>
                    <span class="hidden md:inline" data-i18n="brd_dash_console">Console: v2.4.0-STABLE</span>
                </div>
                <div class="flex gap-6 uppercase tracking-wider">
                    <span class="flex items-center gap-1.5"
                        ><div class="w-1.5 h-1.5 bg-[#34D399] rounded-full">
                        </div> <span data-i18n="brd_dash_gps">GPS: LOCKED</span></span
                    >
                    <span class="flex items-center gap-1.5"
                        ><div class="w-1.5 h-1.5 bg-[#34D399] rounded-full">
                        </div> <span data-i18n="brd_dash_rtk">RTK: FIXED</span></span
                    >
                    <span class="hidden sm:flex items-center gap-1.5"
                        ><div class="w-1.5 h-1.5 bg-[#00E0FF] rounded-full">
                        </div> <span data-i18n="brd_dash_adsb">ADS-B: ON</span></span
                    >
                </div>
            </footer>
        </div>
    </div>

    <!-- Software Capabilities Section -->
    <div class="max-w-screen-2xl mx-auto mt-24 px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div
                class="p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow"
            >
                <div
                    class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 mb-6"
                >
                    <Plane size={24} />
                </div>
                <h3
                    class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
                 data-i18n="brd_feat_patrols_t">
                    Automated Patrols
                </h3>
                <p class="text-slate-500 leading-relaxed text-sm" data-i18n="brd_feat_patrols_d">
                    The drones run automated patrol routes day and night, in
                    darkness and bad weather. Thermal cameras spot people moving
                    through dense vegetation or river crossings before ground
                    units are aware.
                </p>
            </div>

            <div
                class="p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow"
            >
                <div
                    class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600 mb-6"
                >
                    <Zap size={24} />
                </div>
                <h3
                    class="text-xl font-bold text-slate-900 mb-4 uppercase tracking-tight"
                 data-i18n="brd_feat_ai_t">
                    AI Recognition
                </h3>
                <p class="text-slate-500 leading-relaxed text-sm" data-i18n="brd_feat_ai_d">
                    AI identifies what the drone sees in real time — people
                    versus animals, group size, direction of travel — so
                    operators receive confirmed alerts, not hours of raw footage
                    to review manually.
                </p>
            </div>

            <div
                class="p-8 bg-white rounded-3xl border border-slate-100 shadow-sm hover:shadow-md transition-shadow"
            >
                <div
